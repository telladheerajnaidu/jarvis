# Copy to .env.local and fill with the real roster for this interview loop.
# .env.local is gitignored. Never commit real creds.

JARVIS_SECRET=change-me-in-prod

# JSON array of {email, password, name}. USERS[0] is unlocked by /api/admin/grant.
JARVIS_USERS=[{"email":"first@example.com","password":"changeme","name":"First Last"}]
